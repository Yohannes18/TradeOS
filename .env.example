# ─── Supabase ─────────────────────────────────────────────────────────────────
# Anon key is safe client-side — RLS policies MUST be configured and verified
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# SERVER ONLY — never use NEXT_PUBLIC_ prefix on this key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard

# ─── Cron Protection ──────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Set in Vercel dashboard — Vercel Cron sends this as Bearer token automatically
CRON_SECRET=your-minimum-32-char-random-secret

# ─── Rate Limiting ────────────────────────────────────────────────────────────
# Free tier at upstash.com — install: npm i @upstash/ratelimit @upstash/redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── AI Analysis (SERVER ONLY) ────────────────────────────────────────────────
GEMINI_API_KEY=your-key
DEEPSEEK_API_KEY=your-key

# ─── Market Data (SERVER ONLY) ────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=your-key
FINNHUB_API_KEY=your-key
X_NEWS_RSS_URL=

# ─── Scoring Weights (SERVER ONLY, auto-normalized) ───────────────────────────
MACRO_CONFIDENCE_CHECKLIST_WEIGHT=0.5
MACRO_CONFIDENCE_MACRO_WEIGHT=0.3
MACRO_CONFIDENCE_INDEX_WEIGHT=0.2

# ─── Error Tracking ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
