# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
BETTER_AUTH_ENABLED=true
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-min-32-chars
NEXT_PUBLIC_BETTER_AUTH_ENABLED=true
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/dashboard

# Market Data (optional - macro desk falls back to static data if missing)
ALPHA_VANTAGE_API_KEY=your-key
FINNHUB_API_KEY=your-key
MARKET_DATA_USER_AGENT="Mozilla/5.0 (compatible; TradeOS/1.0)"

# AI (used by /api/ai-analysis — Claude API key is auto-injected in claude.ai artifacts)
# No key needed when deployed via Vercel + Anthropic integration

# Macro brief cron weights
MACRO_CONFIDENCE_CHECKLIST_WEIGHT=0.4
MACRO_CONFIDENCE_MACRO_WEIGHT=0.2
MACRO_CONFIDENCE_INDEX_WEIGHT=0.4

# Rate limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
